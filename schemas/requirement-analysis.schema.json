{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/requirement-analysis.schema.json",
  "title": "AI Requirement Analysis Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "analysis_meta",
    "requirement_cards",
    "open_questions",
    "evidence_index"
  ],
  "properties": {
    "analysis_meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_name",
        "generated_at",
        "source_count"
      ],
      "properties": {
        "project_name": {
          "type": "string",
          "minLength": 1
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "source_count": {
          "type": "integer",
          "minimum": 1
        },
        "analyst_notes": {
          "type": "string"
        }
      }
    },
    "requirement_cards": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/requirementCard"
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_index": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence"
      }
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "source_type",
        "source_title",
        "locator",
        "excerpt",
        "evidence_type"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "pattern": "^SRC-[0-9]{3,}$"
        },
        "source_type": {
          "enum": [
            "interview",
            "policy",
            "process",
            "system",
            "data",
            "feedback",
            "other"
          ]
        },
        "source_title": {
          "type": "string",
          "minLength": 1
        },
        "source_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "source_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "locator": {
          "type": "string",
          "minLength": 1
        },
        "excerpt": {
          "type": "string",
          "minLength": 1
        },
        "evidence_type": {
          "enum": [
            "direct",
            "cross_validated",
            "inferred"
          ]
        },
        "evidence_confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        }
      }
    },
    "aiAssessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fit",
        "capabilities",
        "rationale",
        "data_dependencies",
        "system_dependencies",
        "human_review_points",
        "risks"
      ],
      "properties": {
        "fit": {
          "enum": [
            "high",
            "medium",
            "low",
            "not_recommended"
          ]
        },
        "capabilities": {
          "type": "array",
          "items": {
            "enum": [
              "llm_qa",
              "rag",
              "information_extraction",
              "classification",
              "content_generation",
              "workflow_assistance",
              "rules_engine",
              "analytics",
              "none"
            ]
          },
          "uniqueItems": true
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "data_dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "system_dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "human_review_points": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "productProposal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "form",
        "description",
        "alternative_non_ai"
      ],
      "properties": {
        "form": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "alternative_non_ai": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "requirementCard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement_id",
        "title",
        "user_role",
        "business_stage",
        "scenario",
        "user_goal",
        "pain_point",
        "problem_type",
        "root_cause",
        "business_impact",
        "evidence",
        "ai_assessment",
        "product_proposal",
        "priority",
        "confidence",
        "validation_status",
        "open_questions"
      ],
      "properties": {
        "requirement_id": {
          "type": "string",
          "pattern": "^REQ-[0-9]{3,}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "user_role": {
          "type": "string",
          "minLength": 1
        },
        "business_stage": {
          "type": "string",
          "minLength": 1
        },
        "scenario": {
          "type": "string",
          "minLength": 1
        },
        "user_goal": {
          "type": "string",
          "minLength": 1
        },
        "current_behavior": {
          "type": "string"
        },
        "pain_point": {
          "type": "string",
          "minLength": 1
        },
        "problem_type": {
          "enum": [
            "process_efficiency",
            "information_access",
            "system_usability",
            "cross_department_collaboration",
            "data_quality",
            "risk_supervision",
            "decision_support",
            "other"
          ]
        },
        "root_cause": {
          "type": "string",
          "minLength": 1
        },
        "business_impact": {
          "type": "string",
          "minLength": 1
        },
        "frequency": {
          "enum": [
            "high",
            "medium",
            "low",
            "unknown"
          ]
        },
        "impact_scope": {
          "type": "string"
        },
        "severity": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "ai_assessment": {
          "$ref": "#/$defs/aiAssessment"
        },
        "product_proposal": {
          "$ref": "#/$defs/productProposal"
        },
        "priority": {
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3",
            "defer"
          ]
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "validation_status": {
          "enum": [
            "validated",
            "partially_validated",
            "pending",
            "conflicted"
          ]
        },
        "open_questions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}